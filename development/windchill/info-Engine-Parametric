## Реализация клиентской логики на стороне внешней системы

Чтобы собрать этот запрос воедино, напишем объектно-ориентированный модуль на Python. Он берет на себя рутину по формированию правильной структуры `WHERE` из обычного списка.

```python
import requests
class WindchillNomenclatureProvider:
    """Компонент для выгрузки номенклатуры из Windchill с поддержкой фильтрации по массиву контекстов."""
    def __init__(self, endpoint_url: str, credentials: tuple):
        """
        Инициализирует провайдер данных.
        :param endpoint_url: Полный URL к таске Info*Engine.
        :param credentials: Кортеж авторизации (логин, пароль).
        """
        self._url = endpoint_url
        self._auth = credentials
    def _compile_projects_expression(self, project_ids: list) -> str:
        """
        Преобразует список ID проектов в синтаксическую конструкцию Info*Engine.
        :param project_ids: Список числовых идентификаторов проектов.
        :return: Строка вида (containerReference.key.id=1|containerReference.key.id=2)
        """
        statements = [f"containerReference.key.id={pid}" for pid in project_ids]
        return f"({'|'.join(statements)})"
    def execute_request(self, project_ids: list, from_date: str) -> list:
        """
        Выполняет запрос к серверу и возвращает отфильтрованную номенклатуру.
        :param project_ids: Массив ID проектов для выборки.
        :param from_date: Строка даты ограничения (UTC).
        :return: Массив найденных деталей.
        """
        projects_filter = self._compile_projects_expression(project_ids)
        payload = {
            "projectsFilter": projects_filter,
            "startDate": from_date,
            "accept": "application/json"
        }
        response = requests.post(self._url, data=payload, auth=self._auth, verify=False)
        response.raise_for_status()
        return response.json().get("project_nomenclature", [])

```

